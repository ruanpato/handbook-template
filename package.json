{
  "name": "handbook-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable bilingual technical-handbook template (Markdown + MkDocs).",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "lint": "npm run lint:md && npm run lint:spell && npm run parity",
    "lint:md": "markdownlint-cli2",
    "lint:spell": "cspell \"content/**/*.md\" \"*.md\" --no-progress",
    "parity": "bash scripts/check-i18n-parity.sh"
  },
  "devDependencies": {
    "@cspell/dict-pt-br": "^2.4.2",
    "cspell": "^8.19.4",
    "markdownlint-cli2": "^0.22.1"
  }
}
